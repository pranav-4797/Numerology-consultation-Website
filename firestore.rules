rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Public collections - allow read access for all users
    match /blogs/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /services/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /workshops/{workshopId} {
      allow read: if true;
      allow create, delete: if request.auth != null;
      // Admin can update freely. Public (unauthenticated) updates are only
      // allowed to decrement availableSeats by exactly 1 (workshop registration),
      // and only while seats remain.
      allow update: if request.auth != null ||
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['availableSeats']) &&
          request.resource.data.availableSeats == resource.data.availableSeats - 1 &&
          resource.data.availableSeats > 0
        );
    }

    match /events/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /testimonials/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /gallery/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /siteSettings/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Products catalogue - public read, admin-only write
    match /products/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Contact form submissions: anyone can create, only admin can read/manage
    match /contacts/{contactId} {
      allow read, update, delete: if request.auth != null;
      allow create: if
        request.resource.data.name is string &&
        request.resource.data.phone is string &&
        request.resource.data.email is string &&
        request.resource.data.message is string &&
        request.resource.data.name.size() <= 200 &&
        request.resource.data.message.size() <= 5000;
    }

    // Appointment bookings: anyone can create a pending request, only admin can read/manage
    match /appointments/{appointmentId} {
      allow read, update, delete: if request.auth != null;
      allow create: if
        request.resource.data.name is string &&
        request.resource.data.phone is string &&
        request.resource.data.email is string &&
        request.resource.data.date is string &&
        request.resource.data.timeSlot is string &&
        request.resource.data.status == 'pending' &&
        request.resource.data.paid == false &&
        request.resource.data.name.size() <= 200;
    }

    // Workshop registrations: anyone can create, only admin can read/manage
    match /registrations/{registrationId} {
      allow read, update, delete: if request.auth != null;
      allow create: if
        request.resource.data.name is string &&
        request.resource.data.phone is string &&
        request.resource.data.email is string &&
        request.resource.data.workshopId is string &&
        request.resource.data.status == 'registered' &&
        request.resource.data.paid == false &&
        request.resource.data.name.size() <= 200;
    }

    // Orders: anyone can create, only admin can read/manage
    match /orders/{orderId} {
      allow read, update, delete: if request.auth != null;
      allow create: if
        request.resource.data.name is string &&
        request.resource.data.phone is string &&
        request.resource.data.address is string &&
        request.resource.data.district is string &&
        request.resource.data.state is string &&
        request.resource.data.pincode is string &&
        request.resource.data.total is number &&
        request.resource.data.status == 'pending';
    }

    // Default: deny all
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}

